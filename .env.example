# Server
PORT=8080
GRPC_PORT=9090
PUBLIC_DIR=./public
SERVE_FRONTEND=true
ALLOW_ORIGIN=*
BASE_URL=http://localhost:8080

# Database
DATABASE_URL=postgres://<db_user>:<db_password>@localhost:5432/auth_service?sslmode=disable

# Redis (required for magic links, passkeys, 2FA, rate limiting)
REDIS_URL=redis://<redis_user>:<redis_password>@localhost:6379/0
REDIS_KEY_PREFIX=auth:

# Master admin API key (for client management endpoints)
ADMIN_API_KEY=<generate-a-strong-random-key>

# JWT defaults (clients can have their own secrets)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Refresh cookie/session behavior
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# Password hashing
BCRYPT_COST=12
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=72
PASSWORD_MIN_UNIQUE=4
PASSWORD_BLOCK_COMMON=true
PASSWORD_BLOCK_USER_INFO=true
BLOCKED_EMAIL_DOMAINS=10minutemail.com,dispostable.com,guerrillamail.com,guerrillamail.net,mailinator.com,maildrop.cc,sharklasers.com,tempmail.com,throwawaymail.com,yopmail.com

# Signed audit-event webhooks
WEBHOOK_SIGNING_SECRET=
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_TIMEOUT=5s

# Optional CAPTCHA / bot verification
CAPTCHA_PROVIDER=
CAPTCHA_SECRET=
CAPTCHA_VERIFY_URL=
CAPTCHA_TIMEOUT=5s
CAPTCHA_SIGNUP_REQUIRED=false
CAPTCHA_LOGIN_REQUIRED=false

# Email (Resend — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=Auth Service <noreply@example.com>

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://authservice.ayushojha.com/api/auth/oauth/google/callback

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=https://authservice.ayushojha.com/api/auth/oauth/github/callback

# OAuth — Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URL=https://authservice.ayushojha.com/api/auth/oauth/microsoft/callback

# OAuth — Apple
APPLE_CLIENT_ID=
APPLE_REDIRECT_URL=https://authservice.ayushojha.com/api/auth/oauth/apple/callback

# WebAuthn (Passkeys)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:8080
WEBAUTHN_DISPLAY_NAME=Auth Service
