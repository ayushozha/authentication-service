# Server
PORT=8080
GRPC_PORT=9090
PUBLIC_DIR=./public
SERVE_FRONTEND=true
ALLOW_ORIGIN=*
BASE_URL=http://localhost:8080

# Database
DATABASE_URL=postgres://admin:i87RfJUBx5HZJuykZt4v9u3zaq10wAqV@localhost:5433/auth_service?sslmode=disable

# Redis (required for magic links, passkeys, 2FA, rate limiting)
REDIS_URL=redis://tapdue_user:BhUK71tUxASNZqOoQGMGJoQjLjhuv5WW@localhost:6380/0
REDIS_KEY_PREFIX=auth:

# Master admin API key (for client management endpoints)
ADMIN_API_KEY=change-me-to-a-strong-key

# JWT defaults (clients can have their own secrets)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Password hashing
BCRYPT_COST=12

# Email (Resend — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=Auth Service <noreply@example.com>

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://authservice.ayushojha.com/api/auth/oauth/google/callback

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=https://authservice.ayushojha.com/api/auth/oauth/github/callback

# OAuth — Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URL=https://authservice.ayushojha.com/api/auth/oauth/microsoft/callback

# OAuth — Apple
APPLE_CLIENT_ID=
APPLE_REDIRECT_URL=https://authservice.ayushojha.com/api/auth/oauth/apple/callback

# WebAuthn (Passkeys)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:8080
WEBAUTHN_DISPLAY_NAME=Auth Service
